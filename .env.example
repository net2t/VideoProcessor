# ╔══════════════════════════════════════════════════════════════════╗
# ║   VideoProcessor — Environment Config                           ║
# ║   Copy this file to .env and fill in your values               ║
# ║   NEVER commit .env to GitHub — it is in .gitignore            ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Google Sheet ID ───────────────────────────────────────────────
# Found in your Sheet URL: docs.google.com/spreadsheets/d/THIS_PART/edit
SPREADSHEET_ID=your_sheet_id_here

# ── Google Drive Folder ID ────────────────────────────────────────
# Found in Drive folder URL: drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── Video Processing Settings ─────────────────────────────────────
# Seconds to trim from the END of each video (removes MagicLight outro)
TRIM_SECONDS=4

# ── Logo / Watermark Cover ────────────────────────────────────────
# Path to your logo.png sticker file (relative to process.py)
LOGO_PATH=assets/logo.png

# Position of logo on video (pixels from corner)
# MagicLight watermark is usually top-left, these positions cover it completely
LOGO_X=7
LOGO_Y=5

# Width of logo in pixels (height scales automatically)
# 200-250px usually covers MagicLight watermark completely
LOGO_WIDTH=300

# Opacity: 1.0 = fully visible, 0.5 = semi-transparent
LOGO_OPACITY=1.0

# ── Endscreen Settings ────────────────────────────────────────────
# Add an endscreen to the end of each video (after trimming)
# Set to false to disable endscreen
ENDSCREEN_ENABLED=true

# Path to endscreen video file (relative to process.py)
# Should be a short video with your branding/outro
ENDSCREEN_VIDEO=assets/endscreen.mp4

# Use full duration of endscreen video (auto-detect)
# If set to a number, it will trim to that duration
ENDSCREEN_DURATION=auto

# ── Local PC Mode Settings ────────────────────────────────────────
# Folder to scan for videos when running locally (leave blank to use downloads/)
# Examples:
#   Windows: INPUT_FOLDER=C:\Users\NADEEM\Downloads
#   Or:      INPUT_FOLDER=E:\Pythons\Youtube\Done
INPUT_FOLDER=E:\Pythons\VideoProcessor\downloads

# Where to save processed videos locally (leave blank = same folder as input)
# Example: OUTPUT_FOLDER=E:\Pythons\Youtube\Processed
OUTPUT_FOLDER=E:\Pythons\VideoProcessor\Done
